# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase admin (required for sync scripts)
SUPABASE_SECRET_KEY=your-service-role-key

# Google Gemini (required for LLM material extraction in sync scripts)
GOOGLE_GENAI_API_KEY=your-gemini-api-key

# PostHog analytics (optional — helpers no-op when unset)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
