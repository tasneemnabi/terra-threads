      "children": [
        {
          "id": "I50Ks",
          "type": "ref",
          "ref": "FXRE8",
          "width": "fill_container",
          "name": "aboutNav"
        },
        {
          "type": "frame",
          "id": "cLOAT",
          "name": "AboutHero",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 20,
          "padding": [
            64,
            60,
            48,
            60
          ],
          "children": [
            {
              "type": "text",
              "id": "QMkCG",
              "name": "aboutLabel",
              "fill": "#A3535A",
              "content": "ABOUT",
              "fontFamily": "DM Sans",
              "fontSize": 11,
              "fontWeight": "500",
              "letterSpacing": 2
            },
            {
              "type": "text",
              "id": "regAj",
              "name": "aboutTitle",
              "fill": "#2C2420",
              "textGrowth": "fixed-width",
              "width": 520,
              "content": "We help you find\nclothing without the\nplastic.",
              "lineHeight": 1.1,
              "fontFamily": "Space Grotesk",
              "fontSize": 48,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "mpnqY",
              "name": "aboutDesc",
              "fill": "#475658",
              "textGrowth": "fixed-width",
              "width": 420,
              "content": "FIBER is a curated directory of brands that make clothing from natural fibers — merino wool, organic cotton, linen, hemp, silk, and more. No polyester. No nylon. No greenwashing.",
              "lineHeight": 1.6,
              "fontFamily": "DM Sans",
              "fontSize": 15,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "ytSPO",
          "name": "Mission",
          "width": "fill_container",
          "fill": "#EAE3D8",
          "layout": "vertical",
          "gap": 20,
          "padding": [
            64,
            60
          ],
          "children": [
            {
              "type": "text",
              "id": "VgAfM",
              "name": "missionLabel",
              "fill": "#8A7B6E",
              "content": "OUR MISSION",
              "fontFamily": "DM Sans",
              "fontSize": 11,
              "fontWeight": "500",
              "letterSpacing": 2
            },
            {
              "type": "text",
              "id": "5QPTR",
              "name": "missionTitle",
              "fill": "#2C2420",
              "textGrowth": "fixed-width",
              "width": 460,
              "content": "Making natural fiber clothing easy to find.",
              "lineHeight": 1.2,
              "fontFamily": "Space Grotesk",
              "fontSize": 32,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "L9tTU",
              "name": "missionP1",
              "fill": "#475658",
              "textGrowth": "fixed-width",
              "width": 460,
              "content": "The clothing industry is dominated by synthetics. Finding brands that genuinely use natural fibers means hours of research, reading labels, and deciphering vague marketing claims. FIBER does that work for you.",
              "lineHeight": 1.6,
              "fontFamily": "DM Sans",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "0UTOH",
              "name": "missionP2",
              "fill": "#475658",
              "textGrowth": "fixed-width",
              "width": 460,
              "content": "We research every brand we feature, verifying their materials and cataloging their fiber compositions. The result is a directory you can trust — every brand on FIBER has been reviewed by hand.",
              "lineHeight": 1.6,
              "fontFamily": "DM Sans",
              "fontSize": 14,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "Aovva",
          "name": "Why Natural Fibers",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 20,
          "padding": [
            64,
            60
          ],
          "children": [
            {
              "type": "text",
              "id": "XDV02",
              "name": "whyLabel",
              "fill": "#8A7B6E",
              "content": "WHY NATURAL FIBERS",
              "fontFamily": "DM Sans",
              "fontSize": 11,
              "fontWeight": "500",
              "letterSpacing": 2
            },
            {
              "type": "text",
              "id": "RW11j",
              "name": "whyTitle",
              "fill": "#2C2420",
              "textGrowth": "fixed-width",
              "width": 460,
              "content": "60% of clothing is made from plastic.",
              "lineHeight": 1.2,
              "fontFamily": "Space Grotesk",
              "fontSize": 32,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "OCsYu",
              "name": "whyP1",
              "fill": "#475658",
              "textGrowth": "fixed-width",
              "width": 460,
              "content": "Polyester is a plastic derived from petroleum, and it dominates the clothing industry. Every time you wash a synthetic garment, it releases hundreds of thousands of microplastic fibers into our waterways — fibers that end up in our oceans, our food, and our bodies.",
              "lineHeight": 1.6,
              "fontFamily": "DM Sans",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "kaJDV",
              "name": "whyP2",
              "fill": "#475658",
              "textGrowth": "fixed-width",
              "width": 460,
              "content": "Natural fibers are different. Merino wool regulates temperature. Linen gets softer with every wash. Cotton breathes. Hemp is naturally antimicrobial. And when their life is over, they biodegrade — they don't sit in a landfill for 200 years.",
              "lineHeight": 1.6,
              "fontFamily": "DM Sans",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "ufYFN",
              "name": "whyStats",
              "width": "fill_container",
              "gap": 60,
              "padding": [
                16,
                0,
                0,
                0
              ],
              "children": [
                {
                  "type": "frame",
                  "id": "jsD7e",
                  "name": "ws1",
                  "layout": "vertical",
                  "gap": 4,
                  "children": [
                    {
                      "type": "text",
                      "id": "TxXOh",
                      "name": "ws1Num",
                      "fill": "#A3535A",
                      "content": "60%",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 36,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "BgUcI",
                      "name": "ws1Desc",
                      "fill": "#475658",
                      "textGrowth": "fixed-width",
                      "width": 140,
                      "content": "of clothing contains\npolyester",
                      "lineHeight": 1.4,
                      "fontFamily": "DM Sans",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "igC15",
                  "name": "ws2",
                  "layout": "vertical",
                  "gap": 4,
                  "children": [
                    {
                      "type": "text",
