                      "fill": "#A3535A",
                      "content": "700K",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 36,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "gFqfY",
                      "name": "ws2Desc",
                      "fill": "#475658",
                      "textGrowth": "fixed-width",
                      "width": 140,
                      "content": "microfibers released per\nwash cycle",
                      "lineHeight": 1.4,
                      "fontFamily": "DM Sans",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "pOAoZ",
                  "name": "ws3",
                  "layout": "vertical",
                  "gap": 4,
                  "children": [
                    {
                      "type": "text",
                      "id": "TyzoP",
                      "name": "ws3Num",
                      "fill": "#A3535A",
                      "content": "200+",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 36,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
