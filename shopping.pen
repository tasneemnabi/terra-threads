              "fontFamily": "Space Grotesk",
              "fontSize": 28,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "yQJe4",
              "name": "affiliateDesc",
              "fill": "#475658",
              "textGrowth": "fixed-width",
              "width": 460,
              "content": "Some links on FIBER are affiliate links. If you purchase through one of these links, we may earn a small commission at no extra cost to you. This helps us keep the site running, continue researching brands, and maintain the directory. Our curation is never influenced by affiliate relationships.",
              "lineHeight": 1.6,
              "fontFamily": "DM Sans",
