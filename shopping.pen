        {
          "type": "frame",
          "id": "CbRRt",
          "name": "How We Curate",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 20,
          "padding": [
            64,
            60
          ],
          "children": [
            {
              "type": "text",
              "id": "KX6Ci",
              "name": "curateLabel",
              "fill": "#8A7B6E",
              "content": "HOW WE CURATE",
              "fontFamily": "DM Sans",
              "fontSize": 11,
              "fontWeight": "500",
              "letterSpacing": 2
            },
            {
              "type": "text",
              "id": "s9V97",
              "name": "curateTitle",
              "fill": "#2C2420",
              "textGrowth": "fixed-width",
              "width": 460,
              "content": "Two tiers. Full transparency.",
              "lineHeight": 1.2,
              "fontFamily": "Space Grotesk",
              "fontSize": 32,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "aIgFY",
              "name": "curateDesc",
              "fill": "#475658",
              "textGrowth": "fixed-width",
              "width": 460,
              "content": "Not all \"natural\" brands are created equal. Some use 100% natural fibers across their entire catalog. Others include a small amount of elastane for stretch. We think both deserve recognition — but you deserve to know the difference.",
              "lineHeight": 1.6,
              "fontFamily": "DM Sans",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "w6nS1",
              "name": "tier1",
              "width": 460,
              "fill": "#FAF7F2",
              "cornerRadius": 8,
              "stroke": {
                "thickness": 1,
                "fill": "#D6CBBD"
              },
              "layout": "vertical",
              "gap": 12,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "tdGlW",
                  "name": "tier1Title",
                  "fill": "#2C2420",
                  "content": "100% Natural",
                  "fontFamily": "Space Grotesk",
                  "fontSize": 16,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "aXx2p",
                  "name": "tier1Desc",
                  "fill": "#475658",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Zero synthetics in the entire catalog. Every garment is made exclusively from natural or plant-derived fibers — wool, cotton, linen, hemp, silk, Tencel, lyocell, and modal.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "WOhRR",
              "name": "tier2",
              "width": 460,
              "fill": "#FAF7F2",
              "cornerRadius": 8,
              "stroke": {
                "thickness": 1,
                "fill": "#D6CBBD"
              },
              "layout": "vertical",
              "gap": 12,
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "PjpFL",
                  "name": "tier2Title",
                  "fill": "#2C2420",
                  "content": "Nearly Natural",
                  "fontFamily": "Space Grotesk",
                  "fontSize": 16,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "9Y2e5",
                  "name": "tier2Desc",
                  "fill": "#475658",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Up to 10% elastane or spandex for stretch, with the remaining 90%+ from natural fibers. Semi-synthetics like Tencel, lyocell, and modal are treated as natural. Polyester, nylon, and acrylic are banned in any amount.",
                  "lineHeight": 1.6,
                  "fontFamily": "DM Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "text",
              "id": "Z4gKn",
              "name": "curateBottom",
              "fill": "#475658",
              "textGrowth": "fixed-width",
              "width": 460,
              "content": "We display the full material composition for every brand so you can make informed choices. Transparency is non-negotiable.",
              "lineHeight": 1.6,
              "fontFamily": "DM Sans",
              "fontSize": 14,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
